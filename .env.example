

# --- Postgres (primary relational store: orgs, users, tickets, billing) ---
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=neondb
DATABASE_URL="Database_url"
# --- MongoDB (unstructured: chat transcripts, activity logs, attachments meta) ---
MONGO_USER=r
MONGO_PASSWORD=
MONGO_DB=

MONGO_URL="mongo_url"

# --- Redis (cache, sessions, BullMQ job queues, rate limiting) ---
REDIS_PASSWORD=saas_dev_password
REDIS_URL=redis://:saas_dev_password@localhost:6379

# --- Elasticsearch (full-text ticket/article search) ---
ELASTICSEARCH_URL=http://localhost:9200

# --- Qdrant (vector store for RAG / semantic search) ---
QDRANT_URL=http://localhost:6333

# --- Kafka (event streaming: ticket.created, message.sent, ai.suggestion, etc.) ---
KAFKA_BROKERS=localhost:9092

# --- Auth ---
JWT_ACCESS_SECRET="secret_key"
JWT_REFRESH_SECRET="secret_key"
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# --- Chat widget (public, embedded on third-party sites) ---
WIDGET_JWT_SECRET="secret_key"
WIDGET_JWT_TTL=90d

# --- AI provider (Google Gemini) ---
GOOGLE_API_KEY="gemini_key"
AI_SERVICE_URL=http://localhost:8000
AI_SERVICE_URL=http://localhost:8000

# --- App URLs ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_AI_URL=http://localhost:8000
API_PORT=4000
AI_SERVICE_PORT=8000

NODE_ENV=development
